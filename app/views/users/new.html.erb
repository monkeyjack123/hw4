<h1 class="mb-4">Signup</h1>

<form action="/users" method="post">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

  <div class="mb-3">
    <label for="username_box" class="form-label">Username</label>
    <input type="text" name="username" id="username_box" class="form-control">
  </div>

  <div class="mb-3">
    <label for="email_box" class="form-label">Email</label>
    <input type="email" name="email" id="email_box" class="form-control">
  </div>

  <div class="mb-3">
    <label for="password_box" class="form-label">Password</label>
    <input type="password" name="password" id="password_box" class="form-control">
  </div>

  <button class="btn btn-success">Signup</button>
</form>